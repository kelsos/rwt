#!/bin/sh
# rwt pre-commit: formatting, static analysis, tests and build must all pass
# before a commit is recorded. Enable once per clone with:
#   git config core.hooksPath .githooks
set -e

cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: gofmt"
unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
	echo "gofmt needed on:" >&2
	echo "$unformatted" >&2
	echo "run: gofmt -w ." >&2
	exit 1
fi

echo "pre-commit: go vet"
go vet ./...

echo "pre-commit: go test"
go test ./...

echo "pre-commit: go build"
go build -o /dev/null ./cmd/rwt

echo "pre-commit: ok"
